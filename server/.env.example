# Server Environment Variables
# Copy this file to .env and fill in your values

# MongoDB connection string
# Intentional gap: no example for Atlas URI — developers may be confused about format
MONGO_URI=mongodb://localhost:27017/task-pipeline

# JWT Secret — used to sign auth tokens
# Intentional gap: weak example secret shown here — interns should flag this
JWT_SECRET=secret123

# Port the Express server runs on
PORT=5000
